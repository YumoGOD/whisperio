APP_NAME=Локальный транскрибатор
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000

DATA_DIR=/app/data
UPLOAD_DIR=/app/data/uploads
WORK_DIR=/app/data/work
TRANSCRIPT_DIR=/app/data/transcripts
LOG_DIR=/app/data/logs
GLOSSARY_DIR=/app/data/glossary
DATABASE_PATH=/app/data/transcriber.db

MAX_UPLOAD_MB=5120
ALLOWED_EXTENSIONS=*

DEFAULT_PROFILE=accuracy_first
WHISPER_MODEL=large-v3
# После скачивания модели — локальный путь к CTranslate2 (без загрузки из сети):
# WHISPER_MODEL=/app/data/models/faster-whisper-large-v3
# Устройство: cuda (GPU), cpu, auto
WHISPER_DEVICE=cuda
# float16 — стандарт для GPU; int8_float16 — меньше VRAM, чуть медленнее; int8 — для CPU
WHISPER_COMPUTE_TYPE=float16
# Число параллельных потоков вывода внутри WhisperModel.
# GPU: держите 1 — BatchedInferencePipeline уже параллелит батч на GPU.
# CPU: можно поднять до 2–4, если num_workers < cpu_threads / batch_size.
WHISPER_NUM_WORKERS=1
# Число потоков ЦП для CTranslate2. 0 = определяется автоматически по числу ядер.
# CPU-режим: установите явно (например, 8) чтобы не занимать все ядра.
# GPU-режим: не влияет на скорость инференса, можно оставить 0.
WHISPER_CPU_THREADS=0
WHISPER_DOWNLOAD_ROOT=/app/data/models
WHISPER_LANGUAGE=ru
WHISPER_TASK=transcribe
# Число сегментов VAD, обрабатываемых параллельно на GPU (BatchedInferencePipeline).
# Профиль задаёт 16. Уменьшите до 8 при OOM, увеличьте до 32 при избытке VRAM.
#WHISPER_BATCH_SIZE=16

WORKER_POLL_SECONDS=5
WORKER_ID=
# Число параллельных воркер-потоков (каждый берёт отдельную задачу из очереди).
# GPU: оставьте 1 — один поток уже насыщает GPU через BatchedInferencePipeline.
#   При concurrency > 1 каждый поток загружает собственную копию модели в VRAM.
# CPU с несколькими большими файлами: можно поднять до 2–4 (подберите с учётом
#   WHISPER_CPU_THREADS, чтобы суммарно не превышать число физических ядер).
WORKER_CONCURRENCY=1

# Голосовой фильтр: убирает гул ниже 200 Гц + loudnorm EBU R128 (I=-16 LUFS, TP=-1.5 dBTP).
# Нормализует уровень тихих записей адаптивно — намного лучше фиксированного volume=1.5x.
ENABLE_LOUDNORM=true
TARGET_SAMPLE_RATE=16000

# Порог "нет речи": если вероятность тишины > порога, 30-сек окно пропускается.
# accuracy_first задаёт 0.95 — чёткая речь с фоновым шумом может получить no_speech_prob ~0.91,
# порог 0.95 не даёт её потерять. Снизьте до 0.85–0.90 если много ложных сегментов.
#WHISPER_NO_SPEECH_THRESHOLD=0.95
# Порог средней лог-вероятности: сегменты ниже порога отбрасываются (< 0 = строже).
# accuracy_first задаёт -3.0 — faster-whisper может отбрасывать по log_prob независимо от
# no_speech (OR-логика); VAD уже отфильтровал тишину. Поднимите до -1.5 при галлюцинациях.
#WHISPER_LOG_PROB_THRESHOLD=-3.0

# VAD (Voice Activity Detection) — Silero VAD внутри faster-whisper.
# Включён в обоих профилях (BatchedInferencePipeline использует VAD для батчинга).
# Эти env-переменные переопределяют настройки профиля, если заданы явно.
# Оставь закомментированными, чтобы профиль управлял VAD сам.
#
# Когда отключать (VAD_FILTER=false):
#   — аудио с постоянным фоновым шумом, где VAD ошибочно режет речь
#   — тихая речь ниже порога обнаружения VAD
# В этих случаях лучше использовать ENABLE_LOUDNORM=true (включён выше).
#VAD_FILTER=true
# Параметры ниже применяются только при VAD_FILTER=true:
# accuracy_first: 600, speed_balanced: 400. Больше — меньше разрывов в речи.
#VAD_MIN_SILENCE_MS=600
# accuracy_first: 1000, speed_balanced: 800. Отступ вокруг речи в мс.
#VAD_SPEECH_PAD_MS=1000
# accuracy_first: 0.2, speed_balanced: 0.25. Ниже — VAD захватывает тихую речь.
#VAD_THRESHOLD=0.2

GLOSSARY_PATH=/app/data/glossary/global.yml
GLOSSARY_PROMPT_MAX_CHARS=700
GLOSSARY_CONTEXT_MAX_CHARS=1200
GLOSSARY_HOTWORDS_MAX=80
GLOSSARY_ENABLE_HOTWORDS=false
GLOSSARY_ENABLE_HARD_NORMALIZATION=true
# Минимальное число слов в сегменте для применения жёстких замен глоссария
GLOSSARY_HARD_MIN_SEGMENT_WORDS=3
# Порог компрессии для обнаружения галлюцинаций (петель повторений)
GLOSSARY_REPETITION_COMPRESSION_THRESHOLD=4.0
