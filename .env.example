# ============================
# Backend / API
# ============================
HOST=0.0.0.0
PORT=8000
STORAGE_DIR=./storage
DB_URL=sqlite:///./storage/db.sqlite
MAX_UPLOAD_SIZE_MB=2048
ALLOWED_EXTENSIONS=mp3,wav,m4a,ogg,flac,mp4,mov,mkv,webm,avi
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================
# Whisper (faster-whisper)
# ============================
# Модели: large-v3 | large-v3-turbo | medium | small | base
WHISPER_MODEL=large-v3
# cuda | cpu | auto
WHISPER_DEVICE=cuda
# float16 | int8_float16 | int8 (для cuda); float32 | int8 (для cpu)
WHISPER_COMPUTE_TYPE=float16
WHISPER_BATCH_SIZE=8
WHISPER_MODELS_DIR=./storage/models
# Пусто = автоопределение
DEFAULT_LANGUAGE=
BEAM_SIZE=5

# ============================
# VAD (Silero)
# ============================
VAD_ENABLED=true
VAD_MIN_SILENCE_MS=500
VAD_SPEECH_PAD_MS=200
VAD_MAX_SEGMENT_SEC=30

# ============================
# Worker
# ============================
WORKER_POLL_INTERVAL_SEC=2
WORKER_HEARTBEAT_SEC=5
STALE_JOB_TIMEOUT_MIN=60

# ============================
# Misc
# ============================
MAX_JOBS_IN_LIST=100
